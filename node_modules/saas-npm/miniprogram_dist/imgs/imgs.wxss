@import '../common.wxss';
.img-box {
  width: 100%;
  position: relative;
}
.img-box .img-list.first {
  width: 100%;
}
.img-box .img-list.first .img-item {
  width: 100%;
  margin-bottom: 20rpx;
  border-radius: 10rpx;
  overflow: hidden;
  background: #fff;
  position: relative;
}
.img-box .img-list.first .img-item:last-child {
  margin-bottom: 0;
}
.img-box .img-list.first .img-item .img-content {
  width: 100%;
  height: 100%;
  display: block;
}
.img-box .img-list.first .img-item .img-desc {
  padding: 0 20rpx;
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  color: #fff;
  font-size: 28rpx;
  line-height: 60rpx;
  background: rgba(0, 0, 0, 0.6);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
