@import '../common.wxss';
.nav-box {
  width: 100%;
  position: relative;
}
.nav-box .nav-top-pic {
  width: 100%;
  height: 214rpx;
  display: block;
}
.nav-box .nav-content {
  background: #fff;
  border-radius: 10rpx;
  margin: 0 20rpx;
  padding: 10rpx 0;
}
.nav-box .nav-content .nav-list.first {
  padding: 14rpx;
}
.nav-box .nav-content .nav-list.first .nav-item {
  align-items: center;
  margin-right: 20rpx;
}
.nav-box .nav-content .nav-list.first .nav-item:last-child {
  margin-right: 0;
}
.nav-box .nav-content .nav-list.first .nav-item.one-row {
  flex: 1;
}
.nav-box .nav-content .nav-list.first .nav-item.more-row {
  width: 156rpx;
}
.nav-box .nav-content .nav-list.first .nav-item .nav-pic {
  width: 100rpx;
  height: 100rpx;
  margin-bottom: 10rpx;
  position: relative;
}
.nav-box .nav-content .nav-list.first .nav-item .nav-pic .icon-info {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translateX(-50%) translateY(-50%);
}
.nav-box .nav-content .nav-list.first .nav-item .nav-name {
  color: #555555;
  font-size: 28rpx;
  line-height: 1;
}
.nav-box .nav-content .nav-list.second {
  padding: 14rpx;
}
.nav-box .nav-content .nav-list.second .nav-item {
  align-items: center;
  margin-right: 30rpx;
}
.nav-box .nav-content .nav-list.second .nav-item:last-child {
  margin-right: 0;
}
.nav-box .nav-content .nav-list.second .nav-item.one-row {
  flex: 1;
}
.nav-box .nav-content .nav-list.second .nav-item.more-row {
  width: 110rpx;
}
.nav-box .nav-content .nav-list.second .nav-item .nav-pic {
  width: 90rpx;
  height: 90rpx;
  margin-bottom: 10rpx;
  position: relative;
}
.nav-box .nav-content .nav-list.second .nav-item .nav-pic .icon-info {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translateX(-50%) translateY(-50%);
}
.nav-box .nav-content .nav-list.second .nav-item .nav-name {
  color: #555555;
  font-size: 28rpx;
  line-height: 1;
}
