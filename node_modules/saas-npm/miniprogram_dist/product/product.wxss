@import '../common.wxss';
.activity-box {
  width: 100%;
}
.activity-box .activity-list.second {
  width: 100%;
}
.activity-box .activity-list.second .activity-content {
  width: 100%;
  margin-bottom: 20rpx;
}
.activity-box .activity-list.second .activity-content:last-child {
  margin-bottom: 4rpx;
}
.activity-box .activity-list.second .activity-content .activity-item {
  flex: 1;
  margin-right: 20rpx;
  border-radius: 10rpx;
  overflow: hidden;
  box-shadow: 0rpx 2rpx 8rpx 0rpx rgba(0, 0, 0, 0.12);
}
.activity-box .activity-list.second .activity-content .activity-item:last-child {
  margin-right: 0;
}
.activity-box .activity-list.second .activity-content .activity-item .banner {
  width: 100%;
  height: 194rpx;
  position: relative;
}
.activity-box .activity-list.second .activity-content .activity-item .banner .banner-img {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
}
.activity-box .activity-list.second .activity-content .activity-item .bottom {
  width: 100%;
  padding: 10rpx 10rpx 14rpx 10rpx;
  background: #fff;
}
.activity-box .activity-list.second .activity-content .activity-item .bottom .title {
  color: #333333;
  font-size: 24rpx;
  line-height: 33rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
  margin-bottom: 3rpx;
}
.activity-box .activity-list.second .activity-content .activity-item .bottom .info {
  align-items: center;
  justify-content: space-between;
}
.activity-box .activity-list.second .activity-content .activity-item .bottom .info .info-text {
  color: #999999;
  font-size: 24rpx;
  line-height: 33rpx;
}
.activity-box .activity-list.second .activity-content .activity-item .bottom .info .price {
  color: #EC001F;
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 500;
}
.activity-box .activity-list.third {
  width: 100%;
}
.activity-box .activity-list.third .activity-item {
  width: 100%;
  background: #fff;
  border-radius: 10rpx;
  box-shadow: 0rpx 2rpx 13rpx 0rpx rgba(0, 0, 0, 0.12);
  overflow: hidden;
  margin-bottom: 20rpx;
}
.activity-box .activity-list.third .activity-item:last-child {
  margin-bottom: 0;
}
.activity-box .activity-list.third .activity-item .activity-item-banner {
  width: 100%;
  height: 400rpx;
  position: relative;
}
.activity-box .activity-list.third .activity-item .activity-item-banner .banner-image {
  width: 100%;
  height: 100%;
  display: block;
}
.activity-box .activity-list.third .activity-item .activity-item-bottom {
  width: 100%;
  padding: 20rpx;
}
.activity-box .activity-list.third .activity-item .activity-item-bottom .activity-title {
  color: #333;
  font-size: 30rpx;
  line-height: 45rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 20rpx;
}
.activity-box .activity-list.third .activity-item .activity-item-bottom .activity-info {
  align-items: center;
  justify-content: space-between;
}
.activity-box .activity-list.third .activity-item .activity-item-bottom .activity-info .activity-text {
  color: #999999;
  font-size: 24rpx;
  line-height: 33rpx;
}
.activity-box .activity-list.third .activity-item .activity-item-bottom .activity-info .activity-price {
  color: #EC001F;
  font-size: 34rpx;
  line-height: 48rpx;
  font-weight: 500;
}
.add-button {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  position: relative;
}
.add-button::after {
  content: '';
  width: 4rpx;
  height: 24rpx;
  background: #fff;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translateX(-50%) translateY(-50%);
}
.add-button::before {
  content: '';
  width: 24rpx;
  height: 4rpx;
  background: #fff;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translateY(-50%) translateX(-50%);
}
