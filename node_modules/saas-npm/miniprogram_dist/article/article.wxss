@import '../common.wxss';
.article-box {
  width: 100%;
}
.article-box .article-list.frist {
  background: #fff;
  width: 100%;
  padding: 0 20rpx;
}
.article-box .article-list.frist .article-item {
  width: 100%;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #EFEFEF;
}
.article-box .article-list.frist .article-item:last-child {
  border-bottom: none;
}
.article-box .article-list.frist .article-item .left {
  flex: 1;
}
.article-box .article-list.frist .article-item .left .title {
  color: #333333;
  font-size: 32rpx;
  line-height: 48rpx;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
}
.article-box .article-list.frist .article-item .left .time {
  color: #999999;
  font-size: 28rpx;
  line-height: 40rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.article-box .article-list.frist .article-item .right {
  width: 234rpx;
  margin-left: 24rpx;
}
.article-box .article-list.frist .article-item .right .banner {
  width: 100%;
  height: 140rpx;
  border-radius: 10rpx;
  display: block;
}
.article-box .article-list.second {
  width: 100%;
}
.article-box .article-list.second .article-item {
  width: 100%;
  background: #fff;
  padding: 28rpx 20rpx 20rpx 20rpx;
  margin-bottom: 20rpx;
}
.article-box .article-list.second .article-item:last-child {
  margin-bottom: 0;
}
.article-box .article-list.second .article-item .title {
  color: #333333;
  font-size: 32rpx;
  line-height: 45rpx;
  margin-bottom: 27rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.article-box .article-list.second .article-item .banner {
  width: 100%;
  height: 400rpx;
  display: block;
  margin-bottom: 20rpx;
}
.article-box .article-list.second .article-item .time {
  color: #999999;
  font-size: 28rpx;
  line-height: 40rpx;
}
