<view class="article-box">
  <!-- 第一种样式 -->
  <view class="article-list frist" wx:if="{{type === 1}}">
    <view class="article-item flex-row" wx:for="{{list}}" wx:key="index" data-item="{{item}}" catchtap="clickItem">
      <view class="left">
        <view class="title">{{item.title}}</view>
        <view class="time">{{item.abstract}}</view>
      </view>
      <view class="right">
        <image class="banner" src="{{item.image}}" mode="scaleToFill"></image>
      </view>
    </view>
  </view>
  <!-- 第二种样式 -->
  <view class="article-list second" wx:elif="{{type === 2}}">
    <view class="article-item" wx:for="{{list}}" wx:key="index" data-item="{{item}}" catchtap="clickItem">
      <view class="title">{{item.title}}</view>
      <image class="banner" src="{{item.image}}" mode="scaleToFill"></image>
      <view class="time">{{item.created_at}}</view>
    </view>
  </view>
</view>