@import '../common.wxss';
.carousel-box {
  width: 100%;
  position: relative;
}
.carousel-box .carousel-list {
  width: 100%;
  height: 374rpx;
  position: relative;
}
.carousel-box .carousel-list .carousel-item {
  width: 100%;
  height: 100%;
  position: relative;
}
.carousel-box .carousel-list .carousel-item .slide-image {
  width: 100%;
  height: 100%;
  display: block;
}
.carousel-cover {
  width: 100%;
  position: absolute;
  bottom: -2rpx;
  right: 0;
}
