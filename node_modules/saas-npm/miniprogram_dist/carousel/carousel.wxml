<view class="carousel-box" wx:if="{{imgUrls.length}}" style="padding: {{border ? '0 10rpx 10rpx 10rpx' : '0'}}">
  <swiper class="carousel-list" indicator-dots="{{indicatorDots}}" autoplay="{{autoplay}}" interval="{{interval}}" duration="{{duration}}" circular="{{true}}" indicator-color="rgba(255,255,255,0.3)" indicator-active-color="#fff">
    <swiper-item class="carousel-item" wx:for="{{imgUrls}}" wx:key="index" data-href="{{item.href}}" catchtap="clickSwiperItem">
      <image src="{{item.image.path}}" class="slide-image"/>
    </swiper-item>
    <!-- <cover-view class="carousel-cover">
      <cover-image  src="{{coverImg}}"></cover-image>
    </cover-view> -->
  </swiper>
  <image class="carousel-cover" wx:if="{{coverImg}}" src="{{coverImg}}" mode="widthFix"></image>
</view>