<view class="button-box">
  <button class="button flex-row {{type > 2 ? 'round' : ''}}" style="background: {{(type === 2 || type === 4) ? 'transparent': bgColor}};color: {{textColor}};border: {{(type === 2 || type === 4) ? '1px solid ' + bgColor : 'none'}}" catchtap="clickButton">
    <image wx:if="{{mobile}}" style="width: 48rpx;height:48rpx;margin-right:20rpx;" src="../assets/mobile.png" mode="scaleToFill"></image>
    <text>{{text}}</text>
  </button>
</view>