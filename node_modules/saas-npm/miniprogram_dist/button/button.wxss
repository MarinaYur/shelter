@import '../common.wxss';
.flex-row {
  display: flex;
  flex-direction: row;
}
.button-box {
  width: 100%;
}
.button-box .button {
  width: 100%;
  height: 80rpx;
  color: #fff;
  font-size: 38rpx;
  border-radius: 10rpx;
  padding: 0;
  align-items: center;
  justify-content: center;
}
.button-box .button::after {
  border: none;
}
.button-box .button.round {
  border-radius: 40rpx;
}
.button-box .button text {
  line-height: 1;
}
