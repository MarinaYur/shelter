<view class="nav-box" style="margin-top: {{navOffset ? '-50rpx' : '0'}}">
  <image wx:if="{{navTopPic}}" class="nav-top-pic" src="{{navTopPic}}" mode="scaleToFill"></image>
  <view class="nav-content" style="box-shadow: {{shadowColor === '#fff' ? 'none' : '0 5rpx 12rpx 5rpx ' + shadowColor}}">
    <!-- 第一种 -->
    <view wx:if="{{type === 1}}" class="nav-list flex-row first" wx:for="{{navListData}}" wx:for-item="navRow" wx:for-index="navIndex" wx:key="navIndex">
      <view class="nav-item flex-col {{navListData.length > 1 ? 'more-row' : 'one-row'}}" wx:for="{{navRow}}" wx:for-item="navItem" wx:key="index" data-href="{{navItem.href}}" catchtap="clickNav">
        <view class="nav-pic">
          <image wx:if="{{backgroundType == 1}}" style="display:block;width:100%;height:100%;" src="{{backgroundVal[index % backgroundVal.length]}}" mode="scaleToFill"></image>
          <view wx:if="{{backgroundType == 0}}" style="width:100%;height:100%;border-radius:50%;background: {{backgroundVal[index % backgroundVal.length]}}"></view>
          <view style="font-size:56rpx;color:#fff;" class="icon-info iconfont {{navItem.icon_class}}"></view>
        </view>
        <view class="nav-name">{{navItem.name}}</view>
      </view>
    </view>
    <!-- 第二种 -->
    <view wx:if="{{type === 2}}" class="nav-list flex-row second" wx:for="{{navListData}}" wx:for-item="navRow" wx:for-index="navIndex" wx:key="navIndex">
      <view class="nav-item flex-col {{navListData.length > 1 ? 'more-row' : 'one-row'}}" wx:for="{{navRow}}" wx:for-item="navItem" wx:key="index" data-href="{{navItem.href}}" catchtap="clickNav">
        <view class="nav-pic">
          <image wx:if="{{backgroundType == 1}}" style="display:block;width:100%;height:100%;" src="{{backgroundVal[index % backgroundVal.length]}}" mode="scaleToFill"></image>
          <view wx:if="{{backgroundType == 0}}" style="width:100%;height:100%;border-radius:50%;background: {{backgroundVal[index % backgroundVal.length]}}"></view>
          <view style="font-size:50rpx;color:#fff;" class="icon-info iconfont {{navItem.icon_class}}"></view>
        </view>
        <view class="nav-name">{{navItem.name}}</view>
      </view>
    </view>
  </view>
</view>