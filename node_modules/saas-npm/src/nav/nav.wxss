@import '../common.wxss';

.nav-box {
  width: 100%;
  position: relative;
  .nav-top-pic {
    width: 100%;
    height: 214rpx;
    display: block;
  }
  .nav-content {
    background: #fff;
    border-radius: 10rpx;
    margin: 0 20rpx;
    padding: 10rpx 0;
    .nav-list.first {
      padding: 14rpx;
      .nav-item {
        align-items: center;
        margin-right: 20rpx;
        &:last-child {
          margin-right: 0;
        }
        &.one-row {
          flex: 1;
        }
        &.more-row {
          width: 156rpx;
        }
        .nav-pic {
          width: 100rpx;
          height: 100rpx;
          margin-bottom: 10rpx;
          position: relative;
          .icon-info {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translateX(-50%) translateY(-50%);
          }
        }
        .nav-name {
          color: #555555;
          font-size: 28rpx;
          line-height: 1;
        }
      }
    }
    .nav-list.second {
      padding: 14rpx;
      .nav-item {
        align-items: center;
        margin-right: 30rpx;
        &:last-child {
          margin-right: 0;
        }
        &.one-row {
          flex: 1;
        }
        &.more-row {
          width: 110rpx;
        }
        .nav-pic {
          width: 90rpx;
          height: 90rpx;
          margin-bottom: 10rpx;
          position: relative;
          .icon-info {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translateX(-50%) translateY(-50%);
          }
        }
        .nav-name {
          color: #555555;
          font-size: 28rpx;
          line-height: 1;
        }
      }
    }
  }
}