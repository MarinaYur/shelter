@import '../common.wxss';

.flex-row {
  display: flex;
  flex-direction: row;
}
.button-box {
  width: 100%;
  .button {
    width: 100%;
    height: 80rpx;
    color: #fff;
    font-size: 38rpx;
    border-radius: 10rpx;
    padding: 0;
    align-items: center;
    justify-content: center;
    &::after {
      border: none;
    }
    &.round {
      border-radius: 40rpx;
    }
    text {
      line-height: 1;
    }
  }
}