@import '../common.wxss';

.nav-box {
  width: 100%;
  position: relative;
  .nav-content {
    background: #fff;
    border-radius: 10rpx;
    margin: 0 20rpx;
    padding: 10rpx 0;
    .nav-list.first {
      padding: 14rpx;
      .nav-item {
        align-items: center;
        margin-right: 20rpx;
        &:last-child {
          margin-right: 0;
        }
        &.one-row {
          flex: 1;
        }
        &.more-row {
          width: 156rpx;
        }
        .nav-pic {
          width: 120rpx;
          height: 120rpx;
          margin-bottom: 10rpx;
          border-radius: 10rpx;
        }
        .nav-name {
          color: #555555;
          font-size: 28rpx;
          line-height: 1;
        }
      }
    }
    .nav-list.second {
      padding: 14rpx;
      .nav-item {
        align-items: center;
        margin-right: 16rpx;
        &:last-child {
          margin-right: 0;
        }
        &.more-row {
          width: 216rpx;
        }
        .nav-pic {
          width: 216rpx;
          height: 216rpx;
          margin-bottom: 10rpx;
          border-radius: 10rpx;
        }
        .nav-name {
          color: #555555;
          font-size: 28rpx;
          line-height: 1;
        }
      }
    }
  }
}