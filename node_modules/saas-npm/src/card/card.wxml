<view class="card-box" wx:if="{{list.length}}">
  <view class="card-list">
    <view class="card-item" wx:for="{{list}}" wx:key="index" data-item="{{item}}" catchtap="clickItem">
      <image class="item-img" src="{{item.image}}" mode="scaleToFill"></image>
      <view class="title">{{item.name}}</view>
      <view class="price flex-row">
        <view class="big">¥{{item.price}}</view>
        <view>/{{item.times}}次</view>
      </view>
      <view class="bottom flex-row">
        <view class="left">已售出：{{item.sale_num}}</view>
        <view class="right">抢购</view>
      </view>
    </view>
  </view>
</view>