@import '../common.wxss';

.card-box {
  width: 100%;
  padding: 0 20rpx 20rpx 20rpx;
  .card-item {
    width: 100%;
    height: 360rpx;
    padding: 60rpx 30rpx 30rpx 40rpx;
    border-radius: 10rpx;
    box-shadow:0rpx 1rpx 6rpx 0rpx rgba(0,0,0,0.12);
    overflow: hidden;
    margin-bottom: 20rpx;
    position: relative;
    &:last-child {
      margin-bottom: 0rpx;
    }
    .item-img {
      width: 100%;
      height: 100%;
      position: absolute;
      top: 0;
      left: 0;
      z-index: 1;
    }
    .title {
      color: #fff;
      font-size: 32rpx;
      line-height: 36rpx;
      position: relative;
      margin-bottom: 44rpx;
      z-index: 2;
    }
    .price {
      align-items: flex-end;
      justify-content: center;
      color: #fff;
      position: relative;
      z-index: 2;
      view {
        font-size: 40rpx;
        line-height: 52rpx;
        &.big {
          font-size: 80rpx;
          line-height: 1;
          text-shadow:0rpx 5rpx 0rpx rgba(0,0,0,0.1);
        }
      }
    }
    .bottom {
      width: 100%;
      align-items: center;
      justify-content: space-between;
      position: absolute;
      bottom: 30rpx;
      left: 0;
      padding: 0 30rpx 0 40rpx;
      color: #fff;
      z-index: 2;
      .left {
        font-size: 26rpx;
        line-height: 1;
      }
      .right {
        width: 140rpx;
        height: 60rpx;
        text-align: center;
        justify-content: center;
        font-size: 28rpx;
        line-height: 56rpx;
        border: 2rpx solid #fff;
        border-radius: 30rpx;
        overflow: hidden;
      }
    }
  }
}