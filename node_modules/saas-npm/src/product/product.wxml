<wxs src="../common.wxs" module="commonComputed" />

<view class="activity-box" wx:if="{{list.length}}">
  <!-- 第二种样式 -->
  <view class="activity-list second" wx:if="{{type === 1}}">
    <view class="activity-content flex-row" wx:for="{{dealList}}" wx:for-item="list" wx:for-index="rowList" wx:key="rowList">
      <view class="activity-item" style="box-shadow: {{item.title ? '0rpx 2rpx 13rpx 0rpx rgba(0,0,0,0.12)' : 'none'}}" wx:for="{{list}}" wx:key="index" data-item="{{item}}" catchtap="clickItem">
        <view class="banner" wx:if="{{item.image}}">
          <image class="banner-img" src="{{item.image}}" mode="scaleToFill"></image>
        </view>
        <view class="bottom" wx:if="{{item.image}}">
          <view class="title">{{item.title ? item.title : item.name}}</view>
          <block wx:if="{{!item.add}}">
            <view class="info flex-row">
              <view class="info-text">{{commonComputed.hasKey(item, 'show_class_hour') ? '课时：' : commonComputed.hasKey(item, 'sale_num') ? '销量：' : ''}}{{commonComputed.hasKey(item, 'show_class_hour') ? item.show_class_hour : commonComputed.hasKey(item, 'sale_num') ? item.sale_num : item.created_at.slice(0, 10)}}</view>
              <view class="price">{{commonComputed.hasKey(item, 'show_price') ? '￥' : commonComputed.hasKey(item, 'price') ? '￥' : ''}}{{commonComputed.hasKey(item, 'show_price') ? item.show_price : commonComputed.hasKey(item, 'price') ? item.price : ''}}</view>
            </view>
          </block>
          <block wx:else>
            <view>
              <view class="info-text" style="margin-top:10rpx;">{{commonComputed.hasKey(item, 'show_class_hour') ? '课时：' : commonComputed.hasKey(item, 'sale_num') ? '销量：' : ''}}{{commonComputed.hasKey(item, 'show_class_hour') ? item.show_class_hour : commonComputed.hasKey(item, 'sale_num') ? item.sale_num : item.created_at.slice(0, 10)}}</view>
              <view class="info flex-row">
                <view class="price">{{commonComputed.hasKey(item, 'show_price') ? '￥' : commonComputed.hasKey(item, 'price') ? '￥' : ''}}{{commonComputed.hasKey(item, 'show_price') ? item.show_price : commonComputed.hasKey(item, 'price') ? item.price : ''}}</view>
                <view class="add-button" style="background: {{themeColor}}" catchtap="clickAdd" data-item="{{item}}"></view>
              </view>
            </view>
          </block>
        </view>
      </view>
    </view>
  </view>
  <!-- 第三种样式 -->
  <view class="activity-list third" wx:if="{{type === 2}}">
    <view class="activity-item" wx:for="{{list}}" wx:key="index" data-item="{{item}}" catchtap="clickItem">
      <view class="activity-item-banner">
        <image class="banner-image" src="{{item.image}}"></image>
      </view>
      <view class="activity-item-bottom" wx:if="{{item.image}}">
        <view class="activity-title">{{item.title ? item.title : item.name}}</view>
        <block wx:if="{{!item.add}}">
          <view class="activity-info flex-row">
            <view class="activity-text">{{commonComputed.hasKey(item, 'show_class_hour') ? '课时：' : commonComputed.hasKey(item, 'sale_num') ? '销量：' : '创建时间：'}}{{commonComputed.hasKey(item, 'show_class_hour') ? item.show_class_hour : commonComputed.hasKey(item, 'sale_num') ? item.sale_num : item.created_at}}</view>
            <view class="activity-price">{{commonComputed.hasKey(item, 'show_price') ? '￥' : commonComputed.hasKey(item, 'price') ? '￥' : ''}}{{commonComputed.hasKey(item, 'show_price') ? item.show_price : commonComputed.hasKey(item, 'price') ? item.price : ''}}</view>
          </view>
        </block>
        <block wx:else>
          <view>
             <view class="activity-text" style="margin-bottom:20rpx;">{{commonComputed.hasKey(item, 'show_class_hour') ? '课时：' : commonComputed.hasKey(item, 'sale_num') ? '销量：' : '创建时间：'}}{{commonComputed.hasKey(item, 'show_class_hour') ? item.show_class_hour : commonComputed.hasKey(item, 'sale_num') ? item.sale_num : item.created_at}}</view>
            <view class="activity-info flex-row">
              <view class="activity-price">{{commonComputed.hasKey(item, 'show_price') ? '￥' : commonComputed.hasKey(item, 'price') ? '￥' : ''}}{{commonComputed.hasKey(item, 'show_price') ? item.show_price : commonComputed.hasKey(item, 'price') ? item.price : ''}}</view>
              <view class="add-button" style="background: {{themeColor}}" catchtap="clickAdd" data-item="{{item}}"></view>
            </view>
          </view>
        </block>
      </view>
    </view>
  </view>
</view>