@import '../common.wxss';

.activity-box {
  width: 100%;
  .activity-list.second {
    width: 100%;
    .activity-content {
      width: 100%;
      margin-bottom: 20rpx;
      &:last-child {
        margin-bottom: 4rpx;
      }
      .activity-item {
        flex: 1;
        margin-right: 20rpx;
        border-radius: 10rpx;
        overflow: hidden;
        box-shadow:0rpx 2rpx 8rpx 0rpx rgba(0,0,0,0.12);
        &:last-child {
          margin-right: 0;
        }
        .banner {
          width: 100%;
          height: 194rpx;
          position: relative;
          .banner-img {
            width: 100%;
            height: 100%;
            position: absolute;
            top: 0;
            left: 0;
          }
        }
        .bottom {
          width: 100%;
          padding: 10rpx 10rpx 14rpx 10rpx;
          background: #fff;
          .title {
            color: #333333;
            font-size: 24rpx;
            line-height: 33rpx;
            display: -webkit-box;
            -webkit-box-orient: vertical;
            -webkit-line-clamp: 1;
            overflow: hidden;
            margin-bottom: 3rpx;
          }
          .info {
            align-items: center;
            justify-content: space-between;
            .info-text {
              color: #999999;
              font-size: 24rpx;
              line-height: 33rpx;
            }
            .price {
              color: #EC001F;
              font-size: 28rpx;
              line-height: 40rpx;
              font-weight: 500;
            }
          }
        }
      }
    }
  }
  .activity-list.third {
    width: 100%;
    .activity-item {
      width: 100%;
      background: #fff;
      border-radius: 10rpx;
      box-shadow:0rpx 2rpx 13rpx 0rpx rgba(0,0,0,0.12);
      overflow: hidden;
      margin-bottom: 20rpx;
      &:last-child {
        margin-bottom: 0;
      }
      .activity-item-banner {
        width: 100%;
        height: 400rpx;
        position: relative;
        .banner-image {
          width: 100%;
          height: 100%;
          display: block;
        }
      }
      .activity-item-bottom {
        width: 100%;
        padding: 20rpx;
        .activity-title {
          color: #333;
          font-size: 30rpx;
          line-height: 45rpx;
          display: -webkit-box;
          -webkit-box-orient: vertical;
          -webkit-line-clamp: 2;
          overflow: hidden;
          margin-bottom: 20rpx;
        }
        .activity-info {
          align-items: center;
          justify-content: space-between;
          .activity-text {
            color: #999999;
            font-size: 24rpx;
            line-height: 33rpx;
          }
          .activity-price {
            color: #EC001F;
            font-size: 34rpx;
            line-height: 48rpx;
            font-weight: 500;
          }
        }
      }
    }
  }
}


.add-button {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  position: relative;
  &::after {
    content: '';
    width: 4rpx;
    height: 24rpx;
    background: #fff;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translateX(-50%) translateY(-50%);
  }
  &::before {
    content: '';
    width: 24rpx;
    height: 4rpx;
    background: #fff;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translateY(-50%) translateX(-50%);
  }
}