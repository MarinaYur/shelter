@import '../common.wxss';

.article-box {
  width: 100%;
  .article-list.frist {
    background: #fff;
    width: 100%;
    padding: 0 20rpx;
    .article-item {
      width: 100%;
      padding: 20rpx 0;
      border-bottom: 2rpx solid #EFEFEF;
      &:last-child {
        border-bottom: none;
      }
      .left {
        flex: 1;
        .title {
          color: #333333;
          font-size: 32rpx;
          line-height: 48rpx;
          margin-bottom: 10rpx;
          overflow: hidden;
          text-overflow: ellipsis;
          display: -webkit-box;
          -webkit-line-clamp: 1;
          -webkit-box-orient: vertical;
        }
        .time {
          color: #999999;
          font-size: 28rpx;
          line-height: 40rpx;
          overflow: hidden;
          text-overflow: ellipsis;
          display: -webkit-box;
          -webkit-line-clamp: 2;
          -webkit-box-orient: vertical;
        }
      }
      .right {
        width: 234rpx;
        margin-left: 24rpx;
        .banner {
          width: 100%;
          height: 140rpx;
          border-radius: 10rpx;
          display: block;
        }
      }
    }
  }
  .article-list.second {
    width: 100%;
    .article-item {
      width: 100%;
      background: #fff;
      padding: 28rpx 20rpx 20rpx 20rpx;
      margin-bottom: 20rpx;
      &:last-child {
        margin-bottom: 0;
      }
      .title {
        color: #333333;
        font-size: 32rpx;
        line-height: 45rpx;
        margin-bottom: 27rpx;
        overflow: hidden;
        text-overflow: ellipsis;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
      }
      .banner {
        width: 100%;
        height: 400rpx;
        display: block;
        margin-bottom: 20rpx;
      }
      .time {
        color: #999999;
        font-size: 28rpx;
        line-height: 40rpx;
      }
    }
  }
}
