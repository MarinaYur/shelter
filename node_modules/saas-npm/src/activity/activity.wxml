<view class="activity-box" wx:if="{{list.length}}">
  <!-- 第二种样式 -->
  <view class="activity-list second" wx:if="{{type === 1}}">
    <view class="activity-content flex-row" wx:for="{{dealList}}" wx:for-item="list" wx:for-index="rowList" wx:key="rowList">
      <view class="activity-item" style="box-shadow: {{item.activity_name ? '0rpx 2rpx 13rpx 0rpx rgba(0,0,0,0.12)' : 'none'}}" wx:for="{{list}}" wx:key="index" data-item="{{item}}" catchtap="clickItem">
        <view class="left-top-tips" style="background: {{item.proto_label.icon_color}}">{{item.proto_label.full_name}}</view>
        <view class="banner" wx:if="{{item.image}}">
          <image class="banner-img" src="{{item.image}}" mode="scaleToFill"></image>
        </view>
        <view class="bottom" wx:if="{{item.image}}">
          <view class="title">{{item.activity_name}}</view>
          <view class="info flex-row">
            <view class="info-text">剩余：{{item.total_stock_num}}</view>
            <view class="price">￥{{item.show_price}}</view>
          </view>
        </view>
      </view>
    </view>
  </view>
  <!-- 第三种样式 -->
  <view class="activity-list third" wx:if="{{type === 2}}">
    <view class="activity-item" wx:for="{{list}}" wx:key="index" data-item="{{item}}" catchtap="clickItem">
      <view class="left-top-tips" style="background: {{item.proto_label.icon_color}}">{{item.proto_label.full_name}}</view>
      <view class="activity-item-banner">
        <image class="banner-image" src="{{item.image}}"></image>
      </view>
      <view class="activity-item-bottom">
        <view class="activity-title">{{item.activity_name}}</view>
        <view class="activity-info flex-row">
          <view class="activity-text">剩余：{{item.total_stock_num}}</view>
          <view class="activity-price">￥{{item.show_price}}</view>
        </view>
      </view>
    </view>
  </view>
</view>