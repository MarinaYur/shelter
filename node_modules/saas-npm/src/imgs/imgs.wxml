<view class="img-box">
  <!-- 第一种样式 -->
  <view class="img-list first" wx:if="{{type === 1}}">
    <view class="img-item" wx:for="{{imgs}}" wx:key="index" data-href="{{item.href}}" catchtap="clickImg">
      <image class="img-content" mode="widthFix" src="{{item.image.path}}"></image>
      <div wx:if="{{item.desc}}" class="img-desc">{{item.desc}}</div>
    </view>
  </view>
</view>